# Copy this file to .env and set your values:
#   cp .env.example .env
#
# The UI loads these settings on startup (connection fields stay collapsed).
# Podman Compose also passes .env to the ui service build args when the file exists.
# LLM vars are baked into the React bundle as VITE_* at build time.

# OpenAI-compatible LLM base URL (include /v1, not /chat/completions)
OPENAI_API_ENDPOINT=https://your-llm-host.example.com/v1

# API key for the LLM endpoint
OPENAI_API_TOKEN=sk-your-api-key-here

# Model name accepted by your LLM provider
OPENAI_MODEL=llama-3-3-70b-instruct-w8a8

# Optional: orchestrator URL for the UI (baked as VITE_ORCHESTRATOR_URL at build)
# Default: /api/chat — browser calls same-origin /api/*, nginx/vite proxy to orchestrator
# Override only if you need a direct URL (e.g. http://localhost:5000/chat)
# VITE_ORCHESTRATOR_URL=/api/chat
